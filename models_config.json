{
    "llama3_ollama": {
        "engine": "ollama",
        "install": "curl -fsSL https://ollama.com/install.sh | sh && ollama pull llama3.2",
        "run_cmd": "ollama serve"
    },
    "qwen_lite": {
        "engine": "native",
        "install": "pip install llama-cpp-python --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu",
        "download": "wget -O model.gguf https://huggingface.co/bartowski/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/Qwen2.5-1.5B-Instruct-Q4_K_M.gguf",
        "model_file": "model.gguf"
    },
    "gemma_lite": {
        "engine": "native",
        "install": "pip install llama-cpp-python --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu",
        "download": "wget -O model.gguf https://huggingface.co/bartowski/gemma-2-2b-it-GGUF/resolve/main/gemma-2-2b-it-Q4_K_M.gguf",
        "model_file": "model.gguf"
    }
}
